PORT=8080
DATABASE_PATH=tracky.db

# Ingest auth — collector must present this in X-Tracky-Ingest-Secret.
# Leave empty for local dev to skip the check (logged as a warning).
INGEST_SECRET=

# R2 backlog source for the Drainer. All four required to enable;
# unset any of them to disable the drainer entirely.
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=